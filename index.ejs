<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hyderabad Weather</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #74b9ff, #0984e3);
        min-height: 100vh;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
      }
      .card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        padding: 2rem;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        max-width: 400px;
      }
      h1 {
        font-size: 2.5rem;
        margin: 0 0 1rem;
      }
      .temp {
        font-size: 4rem;
        font-weight: bold;
        margin: 0.5rem 0;
      }
      .details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin: 1.5rem 0;
        text-align: left;
      }
      .detail {
        background: rgba(255, 255, 255, 0.1);
        padding: 1rem;
        border-radius: 10px;
      }
      .label {
        font-size: 0.9rem;
        opacity: 0.8;
      }
      .value {
        font-size: 1.5rem;
        font-weight: bold;
      }
      .time {
        opacity: 0.7;
        font-size: 0.9rem;
      }
      @media (max-width: 600px) {
        .card {
          margin: 1rem;
          padding: 1.5rem;
        }
        .temp {
          font-size: 3rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>🌤️ Hyderabad Weather</h1>
      <div class="temp"><%= temp %>°C</div>
      <div><%= desc %></div>
      <div class="details">
        <div class="detail">
          <div class="label">Feels like</div>
          <div class="value"><%= feels %>°C</div>
        </div>
        <div class="detail">
          <div class="label">Wind</div>
          <div class="value"><%= wind %> km/h</div>
        </div>
      </div>
      <div class="time">Updated: <%= time %> (refreshes every 10 min)</div>
    </div>
    <script>
      setTimeout(() => location.reload(), 600000); // Auto-refresh 10 min
    </script>
  </body>
</html>
